FRONTEND_ENV_FILE=.env
# These NEXT_PUBLIC values are required at Docker build time and runtime.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
BACKEND_API_BASE_URL=http://host.docker.internal:8000
DATASET_ANALYSIS_SERVICE_URL=http://host.docker.internal:8020
DATASET_ANALYSIS_SERVICE_SECRET=ownermate-local-analysis-secret
HOST_PORT=3000
