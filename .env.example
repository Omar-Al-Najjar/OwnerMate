APP_ENV=production
LOG_LEVEL=info

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
SUPABASE_JWT_SECRET=replace-with-your-jwt-secret-if-required

DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DIRECT_URL=postgresql+psycopg://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

API_V1_PREFIX=
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
PORT=8000
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

SENTIMENT_PROVIDER=sentiment_api
SENTIMENT_API_TIMEOUT_SECONDS=60
CONTENT_PROVIDER=mock
GOOGLE_REVIEW_PROVIDER=google_maps_api
GOOGLE_MAPS_API_TIMEOUT_SECONDS=1500
FACEBOOK_REVIEW_PROVIDER=mock
REVIEW_INTELLIGENCE_PROVIDER=mock

BACKEND_API_BASE_URL=http://backend:8000
DATASET_ANALYSIS_SERVICE_URL=http://dataset-analysis:8020
DATASET_ANALYSIS_SERVICE_SECRET=ownermate-local-analysis-secret
DATASET_ANALYSIS_MAX_FILE_MB=10
DATASET_ANALYSIS_MAX_CONCURRENCY=1

OWNERMATE_LLM_API_KEY=your_provider_api_key_here
# Optional compatibility alias for the dataset-analysis service:
# OPENAI_API_KEY=your_provider_api_key_here
OWNERMATE_LLM_MODEL=kimi-k2.5
OWNERMATE_LLM_BASE_URL=https://api.moonshot.ai/v1
OWNERMATE_LLM_TEMPERATURE=0.6
OWNERMATE_AGENT_TIMEOUT=0
OWNERMATE_AGENT_RETRIES=5
OWNERMATE_BATCH_SIZE=5
OWNERMATE_SQL_HEAL_RETRIES=2
OWNERMATE_REFINEMENT_RETRIES=2
OWNERMATE_RESULT_TRIM_CHARS=6000
OWNERMATE_DISABLE_THINKING=true

SENTIMENT_BASE_MODEL=FacebookAI/xlm-roberta-base
SENTIMENT_MAX_LENGTH=128
SENTIMENT_WORKERS=1
GOOGLE_MAPS_SCRAPER_CONCURRENCY=4

FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=8000
GOOGLE_MAPS_API_HOST_PORT=8010
DATASET_ANALYSIS_HOST_PORT=8020
SENTIMENT_HOST_PORT=8030
